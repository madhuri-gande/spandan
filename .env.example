# ===================================================================
# Spandan — Environment Template
# Copy this file to .env and fill in real values BEFORE running.
# Never commit the populated .env (it's in .gitignore for a reason).
# ===================================================================

# ---------- AWS ----------
# On EC2: leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY blank and
# attach an IAM Role to the instance instead — boto3 picks up role
# credentials automatically and they auto-rotate.
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
AWS_DEFAULT_REGION=us-east-1

# Optional — only needed if you want to checkpoint trained ML models
# to S3 (services/ranking.py uploads donor_ranking.pkl). Skip if local
# only.
S3_BUCKET=<your-bucket-or-leave-blank>

# ---------- Bedrock (Claude Haiku 4.5) ----------
# us.<id> = inference profile (cross-region routing). Available models:
#   us.anthropic.claude-haiku-4-5-20251001-v1:0   ← recommended
#   us.anthropic.claude-3-5-haiku-20241022-v1:0   ← cheaper fallback
BEDROCK_GENERATION_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_CLASSIFICATION_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_REGION=us-east-1

# ---------- Agent pacing ----------
AGENT_REPLY_TIMEOUT=25
AGENT_MAX_DONORS=8
AGENT_COOLDOWN_HOURS=2
AGENT_CYCLE_INTERVAL=30

# How long to wait for one donor before emailing the next-ranked donor
# for the same patient. Sequential pacing — never two emails at once.
#  Production:   3600 (1 hour)
#  Hackathon:     300 (5 min)   ← default
#  Live demo:      60 (1 min)
DONOR_WAIT_SECONDS=300

# ---------- Email delivery ----------
# DELIVERY_BACKEND=mailpit  -> route via local MailPit (dev / hackathon)
# DELIVERY_BACKEND=ses      -> send via Amazon SES (production)
DELIVERY_BACKEND=mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=spandan@bloodwarriors.in
SMTP_FROM_NAME=Spandan AI Coordinator
# Local dev:  http://localhost:8025
# EC2 demo:  http://<public-ip>/mail   (requires MAILPIT_WEBROOT=/mail)
MAILPIT_UI_URL=http://localhost:8025
MAILPIT_WEBROOT=

# ---------- Magic-link reply page ----------
# Base URL of the donor /Reply page. On EC2 this becomes the public
# Streamlit URL, e.g. http://<ec2-public-ip>:8501/Reply
REPLY_BASE_URL=http://localhost:8501/Reply

# Used to HMAC-sign donor reply tokens. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
REPLY_TOKEN_SECRET=<generate-a-32+char-random-string>

# ---------- Coordinator login ----------
AUTH_COORDINATOR_USER=coordinator
AUTH_COORDINATOR_PASSWORD=<set-a-strong-password>
# Used by streamlit-authenticator to sign session cookies. Random string.
AUTH_COOKIE_SECRET=<generate-a-32+char-random-string>

# ---------- Reminders ----------
# Look-ahead window for finding upcoming transfusions to remind donors
# about (in hours). 720 = 30 days for the demo dataset.
REMINDER_HOURS_BEFORE=720

# Minutes after a YES confirmation before sending the auto reconfirm.
# 180s (3 min) for demos; 86400 (24h) for production.
REMINDER_DELAY_SECONDS=180

# Don't auto-remind on confirmations older than this. Stops "ghost"
# reminders for stale demo data after a restart.
REMINDER_MAX_AGE_HOURS=1

DEFAULT_CONFIRMATION_TARGET=1
